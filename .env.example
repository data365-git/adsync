# Copy this file to `.env` and fill in every value. `.env` is gitignored.
# See docs/SETUP.md for the manual third-party setup steps.

# ─── Database ────────────────────────────────────────────────────────────────
# compose.yml maps the container's 5432 to host 5434 to avoid conflicting with
# a native Postgres on this machine. If you have no native Postgres on 5432,
# you can switch compose.yml back to "5432:5432" and update this URL.
DATABASE_URL="postgresql://automation:automation@localhost:5434/automation"

# ─── NextAuth (login session) ─────────────────────────────────────────────────
NEXTAUTH_SECRET="<generate: openssl rand -base64 32>"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth — Login (NextAuth provider) ─────────────────────────────────
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# ─── Google OAuth — Sheets data source (separate scopes, separate consent) ────
GOOGLE_OAUTH_SHEETS_CLIENT_ID="..."
GOOGLE_OAUTH_SHEETS_CLIENT_SECRET="..."

# ─── Facebook OAuth — ad data source ─────────────────────────────────────────
FACEBOOK_APP_ID="..."
FACEBOOK_APP_SECRET="..."

# ─── Token encryption ─────────────────────────────────────────────────────────
# 64-character hex string = 32 bytes AES-256 key
# Generate: openssl rand -hex 32
# On Windows PowerShell (no openssl needed):
#   [System.BitConverter]::ToString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)) -replace '-',''
TOKEN_ENC_KEY="..."

# ─── Allowlist ────────────────────────────────────────────────────────────────
ALLOWLIST_EMAIL="jumanovsamandar005@gmail.com"

# ─── Worker behaviour ─────────────────────────────────────────────────────────
WORKER_ENABLED="true"
WORKER_TICK_INTERVAL_MS="60000"

# ─── Facebook API version ─────────────────────────────────────────────────────
FB_GRAPH_API_VERSION="v22.0"

# When the Facebook app is still pending review, certain scopes/audiences are
# unavailable. Set to "true" to surface a banner explaining the limitation;
# "false" (default) hides it. Does not change runtime behaviour.
FACEBOOK_APP_REVIEW_PENDING="false"

# ─── Bitrix24 CRM sync ────────────────────────────────────────────────────────
# Inbound webhook URL from Bitrix24 → Developer → Inbound webhooks.
# Format: https://{portal}.bitrix24.com/rest/{userId}/{token}/
BITRIX24_WEBHOOK_URL="https://yourco.bitrix24.com/rest/1/yourtoken/"

# ─── Google Sheets → Bitrix24 sync ───────────────────────────────────────────
# The spreadsheet ID from the Sheet URL:
#   https://docs.google.com/spreadsheets/d/{GOOGLE_SHEETS_ID}/edit
GOOGLE_SHEETS_ID="1BxiMVs0_..."

# Tab names inside the spreadsheet (defaults shown)
GOOGLE_SHEETS_TAB_LEADS="Leads"
GOOGLE_SHEETS_TAB_DEALS="Deals"
GOOGLE_SHEETS_TAB_CONTACTS="Contacts"

# Service account for server-side Sheets API access.
# 1. Create a service account in Google Cloud Console
# 2. Download the JSON key file
# 3. Share the spreadsheet with the service account email (Viewer role is enough)
# 4. base64-encode the JSON file:
#      Linux/Mac: base64 -w0 key.json
#      Windows:   [Convert]::ToBase64String([IO.File]::ReadAllBytes("key.json"))
GOOGLE_SERVICE_ACCOUNT_EMAIL="sync@your-project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_KEY="<base64-encoded contents of the JSON key file>"

# How often (milliseconds) the worker polls the Sheet. Default: 10000 (10s)
SHEETS_POLL_INTERVAL_MS="10000"
