# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.pnpm-store/

# testing
/coverage

# database
/prisma/db.sqlite
/prisma/db.sqlite-journal
db.sqlite

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log

# local env files
# do not commit any .env files to git, except for the .env.example file. https://create.t3.gg/en/usage/env-variables#using-environment-variables
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo

# idea files
.idea

# parallel-agent worktrees (Stage 1)
.worktrees/

# claude code harness
.claude/

# Lighthouse per-route JSON reports — regenerate on demand, only summary tracked
docs/lighthouse/**/*.json
!docs/lighthouse/**/summary.json

# ─── Personal / scratch artifacts (never push to GitHub) ─────────────────────
# Ad-hoc screenshots you paste into the chat for debugging UI issues. These
# accumulate fast and are useless to anyone else.
docs/errros/
docs/errors/

# Codex / external-agent handoff prompts — single-session scratch, not docs.
docs/codex-audit-fix-prompts.md

# AI-generated specs / scratch from /superpowers — keep them locally if useful,
# don't pollute the repo's history.
docs/superpowers/

# Windows / macOS thumbnail caches that sneak in alongside screenshots
Thumbs.db
desktop.ini
ehthumbs.db

# Editor scratch
*.swp
*.swo
*~

# Loose images at the repo root (drag-and-drop screenshots, etc.)
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/*.bmp
